{
  "name": "vibe-coding-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "coverage": "node --import tsx --test --experimental-test-coverage tests/**/*.test.ts",
    "contract:check": "tsx scripts/contract-check.ts",
    "kpi:report": "tsx scripts/weekly-status-report.ts",
    "smoke": "tsx scripts/post-deploy-smoke.ts",
    "quality:gate": "npm run lint && npm run test && npm run coverage && npm run contract:check"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
